{
  "name": "storybook_vitest_addon",
  "version": "1.0.0",
  "description": "Adds a panel to display Vitest unit test results",
  "keywords": [
    "storybook-addons",
    "addon",
    "storybook",
    "vitest",
    "react",
    "report",
    "test",
    "results",
    "unit-testing"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/krzysztofradomski/storybook-addon-vitest"
  },
  "author": "Krzysztof Radomski <krzysztof@radomski.io>",
  "license": "MIT",
  "main": "dist/cjs/index.js",
  "module": "dist/esm/index.js",
  "types": "dist/ts/index.d.ts",
  "files": [
    "dist/**/*",
    "README.md",
    "*.js",
    "*.d.ts"
  ],
  "scripts": {
    "clean": "rimraf ./dist",
    "buildBabel": "concurrently \"npm run buildBabel:cjs\" \"npm run buildBabel:esm\"",
    "buildBabel:cjs": "babel ./src -d ./dist/cjs --extensions \".js,.jsx,.ts,.tsx\"",
    "buildBabel:esm": "babel ./src -d ./dist/esm --env-name esm --extensions \".js,.jsx,.ts,.tsx\"",
    "buildTsc": "tsc --declaration --emitDeclarationOnly --outDir ./dist/ts",
    "prebuild": "npm run clean",
    "build": "concurrently \"npm run buildBabel\" \"npm run buildTsc\"",
    "build:watch": "concurrently \"npm run buildBabel:esm -- --watch\" \"npm run buildTsc -- --watch\"",
    "test": "vitest run",
    "test:watch": "vitest",
    "storybook": "storybook dev -p 6006",
    "start": "concurrently \"npm run build:watch\" \"npm run storybook \"",
    "build-storybook": "storybook build",
    "release": "npm run build",
    "eject-ts": "zx scripts/eject-typescript.mjs"
  },
  "devDependencies": {
    "@babel/cli": "^7.29.7",
    "@babel/core": "^7.29.7",
    "@babel/preset-env": "^7.29.7",
    "@babel/preset-react": "^7.29.7",
    "@babel/preset-typescript": "^7.29.7",
    "@storybook/react": "^10.4.2",
    "@storybook/react-vite": "^10.4.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^22.15.0",
    "@types/react": "^19.0.0",
    "babel-loader": "^10.1.1",
    "boxen": "^8.0.1",
    "concurrently": "^10.0.3",
    "dedent": "^1.7.2",
    "jsdom": "^29.1.1",
    "prettier": "^3.8.3",
    "prop-types": "^15.8.1",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "rimraf": "^6.0.1",
    "storybook": "^10.4.2",
    "typescript": "^6.0.3",
    "vitest": "^4.1.8",
    "webpack": "^5.107.2",
    "zx": "^8.8.5"
  },
  "peerDependencies": {
    "storybook": "^10.4.2"
  },
  "publishConfig": {
    "access": "public"
  },
  "storybook": {
    "displayName": "Storybook Vitest",
    "supportedFrameworks": [
      "react"
    ],
    "icon": "https://user-images.githubusercontent.com/321738/63501763-88dbf600-c4cc-11e9-96cd-94adadc2fd72.png"
  },
  "dependencies": {
    "@vitejs/plugin-react": "^6.0.2",
    "vite": "^8.0.0"
  }
}
